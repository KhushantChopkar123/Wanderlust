<% layout("/layouts/boilerplate") %>

<style>
body {
    background: #f6f7fb;
    font-family: 'Poppins', sans-serif;
}

/* Page title */
.page-title {
    text-align: center;
    margin: 40px 0 30px;
    font-size: 2rem;
    font-weight: 600;
    color: #333;
}

/* Form container */
.form-box {
    max-width: 700px;
    margin: 0 auto 60px auto;
    background: #fff;
    padding: 45px 35px;
    border-radius: 15px;
    border: 1px solid #e5e5e5;
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
}
.form-box:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.12);
}

/* Labels */
.form-label { font-weight: 500; color: #444; }

/* Buttons */
.add-btn, .update-btn {
    background: #3b82f6 !important;
    color: #fff;
    border-radius: 8px;
    padding: 12px 0;
    font-weight: 500;
    transition: 0.3s;
}
.add-btn:hover, .update-btn:hover { background: #e03150; }

.cancel-btn {
    background: #6c757d;
    color: #fff;
    border-radius: 8px;
    padding: 12px 0;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
}
.cancel-btn:hover { background: #5a6268; }

/* Validation */
.was-validated .form-control:valid,
.was-validated .form-select:valid,
.was-validated textarea:valid {
    border-color: #28a745;
    box-shadow: 0 0 5px rgba(40,167,69,0.3);
}
.was-validated .form-control:invalid,
.was-validated .form-select:invalid,
.was-validated textarea:invalid {
    border-color: #dc3545;
    box-shadow: 0 0 5px rgba(220,53,69,0.3);
}

/* Facilities Dropdown */
.facilities-label { font-weight: 500; margin-bottom: 8px; display:block; }
.facilities-dropdown .dropdown-menu { padding: 15px; width: 100%; }

/* Responsive */
@media (max-width:768px) { .form-box { padding: 35px 25px; } }
@media (max-width:480px) {
    .page-title { font-size: 1.6rem; margin: 30px 0 20px; }
    .add-btn,.update-btn,.cancel-btn { font-size: 0.95rem; padding: 10px 0; }
}
</style>

<div class="container">
    <h2 class="page-title">Edit Your Listing</h2>

    <div class="form-box">
        <form method="post" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">

            <!-- Title -->
            <div class="mb-3">
                <label for="title" class="form-label"><b>Listing Title</b></label>
                <input type="text" id="title" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
                <div class="invalid-feedback">Please enter a title.</div>
            </div>

            <!-- Property Type -->
            <div class="mb-3">
                <label class="form-label"><b>Property Type</b></label>
                <select name="listing[category]" class="form-select" required>
                    <option value="">Select Property Type</option>
                    <option value="PG" <%= listing.category === "PG" ? "selected" : "" %>>PG</option>
                    <option value="Hostel" <%= listing.category === "Hostel" ? "selected" : "" %>>Hostel</option>
                    <option value="Single Room" <%= listing.category === "Single Room" ? "selected" : "" %>>Single Room</option>
                    <option value="Shared Room" <%= listing.category === "Shared Room" ? "selected" : "" %>>Shared Room</option>
                    <option value="Apartment" <%= listing.category === "Apartment" ? "selected" : "" %>>Apartment</option>
                    <option value="Studio" <%= listing.category === "Studio" ? "selected" : "" %>>Studio</option>
                </select>
                <div class="invalid-feedback">Please select a property type.</div>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label for="description" class="form-label"><b>Description</b></label>
                <textarea id="description" name="listing[description]" class="form-control" rows="4" required><%= listing.description %></textarea>
                <div class="invalid-feedback">Please enter a description.</div>
            </div>

            <!-- Current Image -->
            <div class="mb-3">
                <label class="form-label"><b>Current Image</b></label><br>
                <img src="<%= originalImageUrl %>" style="width:200px; border-radius:8px;">
            </div>

            <!-- Upload New Image -->
            <div class="mb-3">
                <label for="image" class="form-label"><b>Upload New Image</b></label>
                <input type="file" id="image" name="listing[image]" class="form-control">
            </div>

            <!-- Monthly Rent -->
            <div class="mb-3">
                <label for="price" class="form-label"><b>Monthly Rent</b></label>
                <input type="number" id="price" name="listing[price]" value="<%= listing.price %>" class="form-control" required min="1">
                <div class="invalid-feedback">Please enter a valid rent amount.</div>
            </div>

            <!-- Location -->
            <div class="mb-3">
                <label for="location" class="form-label"><b>Location</b></label>
                <input type="text" id="location" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
                <div class="invalid-feedback">Please enter the location.</div>
            </div>

            <!-- Nearby College -->
            <div class="mb-3">
                <label for="collegeNearby" class="form-label"><b>Nearby College</b></label>
                <input type="text" id="collegeNearby" name="listing[collegeNearby]" value="<%= listing.collegeNearby %>" class="form-control" required>
                <div class="invalid-feedback">Please enter the nearby college.</div>
            </div>

            <!-- Facilities Dropdown -->
            <div class="mb-3 facilities-dropdown">
                <label class="facilities-label"><b>Facilities</b></label>
                <div class="dropdown">
                    <button class="btn btn-outline-dark dropdown-toggle w-100 text-start" type="button" data-bs-toggle="dropdown">
                        Select Facilities
                    </button>
                    <div class="dropdown-menu w-100">
                        <% const allFacilities = ["WiFi","Food","Parking","Attached Bathroom","Laundry","AC"]; %>
                        <% allFacilities.forEach(function(fac){ %>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="listing[facilities][]" value="<%= fac %>" id="fac-<%= fac.replace(/\s+/g,'') %>"
                            <%= listing.facilities.includes(fac) ? "checked" : "" %>>
                            <label class="form-check-label" for="fac-<%= fac.replace(/\s+/g,'') %>"><%= fac %></label>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <!-- Contact Phone -->
            <div class="mb-3">
                <label for="contactPhone" class="form-label"><b>Owner Contact Number</b></label>
                <input type="text" id="contactPhone" name="listing[contactPhone]" value="<%= listing.contactPhone %>" class="form-control" required pattern="\d{10}">
                <div class="invalid-feedback">Please enter a valid 10-digit phone number.</div>
            </div>

            <!-- Contact Email -->
            <div class="mb-3">
                <label for="contactEmail" class="form-label"><b>Owner Email</b></label>
                <input type="email" id="contactEmail" name="listing[contactEmail]" value="<%= listing.contactEmail %>" class="form-control" required>
                <div class="invalid-feedback">Please enter a valid email.</div>
            </div>

            <!-- Status -->
            <div class="mb-3">
                <label for="status" class="form-label"><b>Room Status</b></label>
                <select name="listing[status]" class="form-select" required>
                    <option value="available" <%= listing.status === "available" ? "selected" : "" %>>Available</option>
                    <option value="rented" <%= listing.status === "rented" ? "selected" : "" %>>Rented</option>
                </select>
                <div class="invalid-feedback">Please select room status.</div>
            </div>

            <!-- Buttons -->
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="update-btn flex-fill">Update Listing</button>
                <a href="/listings" class="cancel-btn flex-fill">Cancel</a>
            </div>

        </form>
    </div>
</div>