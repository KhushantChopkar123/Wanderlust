<style>
    /* NAVBAR */

    .navbar {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        padding: 0.6rem 1.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        transition: 0.3s;
    }


    /* LOGO */

    .navbar-brand i {
        font-size: 1.7rem;
        color: #ff385c;
        transition: 0.3s;
    }

    .navbar-brand i:hover {
        transform: rotate(20deg) scale(1.1);
    }


    /* NAV LINKS */

    .nav-link {
        font-weight: 500;
        color: #333;
        margin-right: 12px;
        position: relative;
        transition: 0.3s;
    }

    .nav-link:hover {
        color: #ff385c;
    }

    .nav-link::after {
        content: "";
        width: 0;
        height: 2px;
        background: #ff385c;
        position: absolute;
        bottom: 0;
        left: 0;
        transition: 0.3s;
    }

    .nav-link:hover::after {
        width: 100%;
    }


    /* SEARCH WRAPPER */

    .search-wrapper {
        flex: 1;
        display: flex;
        justify-content: center;
    }


    /* SEARCH FORM */

    .search-form {
        display: flex;
        align-items: center;
        background: white;
        border-radius: 50px;
        padding: 6px;
        border: 1px solid #eee;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
        gap: 8px;
        transition: 0.3s;
    }

    .search-form:hover {
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.12);
        transform: translateY(-1px);
    }


    /* INPUT */

    .search-inp {
        border: none;
        outline: none;
        height: 40px;
        padding: 0 1rem;
        border-radius: 25px;
        font-size: 0.9rem;
        background: transparent;
    }

    .search-form select {
        border: none;
        outline: none;
        height: 40px;
        padding: 0 0.7rem;
        border-radius: 20px;
        font-size: 0.9rem;
        background: transparent;
    }


    /* SEARCH BUTTON */

    .btn-search {
        background: linear-gradient(135deg, #ff385c, #ff6b6b);
        color: white;
        border-radius: 30px;
        height: 40px;
        padding: 0 1.4rem;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 500;
        transition: 0.3s;
    }

    .btn-search:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(255, 56, 92, 0.4);
    }

    .btn-search i {
        margin-right: 5px;
    }


    /* MOBILE */

    @media (max-width:992px) {

        .search-wrapper {
            margin-top: 10px;
            justify-content: flex-start;
        }

        .search-form {
            flex-wrap: wrap;
            width: 100%;
            padding: 10px;
            border-radius: 15px;
            border-color:20px solid black;
        }

        .search-form input,
        .search-form select {
            width: 100%;
            border: 1px solid #eee;
        }

        .btn-search {
            width: 100%;
            margin-top: 5px;
        }

        .navbar-collapse {
            background: white;
            padding: 1rem;
            border-radius: 10px;
            margin-top: 10px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        }

    }
</style>
<nav class="navbar navbar-expand-md bg-light border-bottom sticky-top">

    <div class="container-fluid">

        <!-- LOGO -->

        <a class="navbar-brand" href="/listings">
            <i class="fa-regular fa-compass"></i>
        </a>

        <!-- MOBILE TOGGLE -->

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

            <!-- LEFT SIDE -->

            <div class="navbar-nav">
                <a class="nav-link" href="/listings">Explore</a>
            </div>

            <!-- CENTER SEARCH -->

            <div class="search-wrapper">

                <form class="search-form" action="/listings" method="GET">

                    <input class="form-control search-inp" type="text" placeholder="Location or College" name="location"
                        style="width:180px;">

                    <select name="category" placeholder="Category" class="form-select" style="width:150px;">

                        <option value="">Category</option>
                        <option value="PG">PG</option>
                        <option value="Hostel">Hostel</option>
                        <option value="Single Room">Single Room</option>
                        <option value="Shared Room">Shared Room</option>
                        <option value="Apartment">Apartment</option>
                        <option value="Studio">Studio</option>

                    </select>

                    <select name="price" class="form-select" style="width:130px;">

                        <option value="">Price</option>
                        <option value="5000">₹5000</option>
                        <option value="10000">₹10000</option>
                        <option value="20000">₹20000</option>

                    </select>

                    <button class="btn btn-search" type="submit">

                        <i class="fa-solid fa-magnifying-glass"></i>

                        Search

                    </button>

                </form>

            </div>

            <!-- RIGHT SIDE -->

            <div class="navbar-nav ms-md-auto text-center text-md-start">

                <a class="nav-link" href="/listings/new">Airbnb your home</a>

                <% if (!currUser) { %>

                    <a class="nav-link" href="/signup"><b>Sign up</b></a>

                    <a class="nav-link" href="/login"><b>Login</b></a>

                    <% } else { %>

                        <a class="nav-link" href="/logout"><b>Logout</b></a>

                        <% } %>

            </div>

        </div>

    </div>

</nav>