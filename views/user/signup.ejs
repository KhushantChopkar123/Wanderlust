<% layout("/layouts/boilerplate") %>

<style>

body{
background-color:#fefafaa8;
}

.signup-box{
max-width:450px;
margin:auto;
padding:35px;
background:white;
border-radius:18px;
border:1px solid #e6e6e6;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

.signup-title{
text-align:center;
margin-bottom:25px;
font-weight:600;
}

.signup-box .form-control{
border-radius:12px;
}

.signup-box .form-control:focus{
border-color:#3b82f6 !important;
box-shadow:0 0 4px rgba(73, 128, 192, 0.525);
}

.signup-btn{
width:100%;
background:#3b82f6 !important;
color:white;
border:none;
padding:10px;
border-radius:12px;
}

.signup-btn:hover{
background:#3b82f6 !important;
}

.login-text{
text-align:center;
margin-top:15px;
}

.login-text a{
text-decoration:none;
color:#3b82f6 !important;
font-weight:600;
}


.mainbox {
  transition: transform 0.35s ease, box-shadow 0.35s ease;
 
}

/* Hover effect (popup feel) */
.mainbox:hover {
  transform: translateY(-8px) scale(1.02);
  
}


</style>


<div class="row mt-5 mb-5">

<div class="col-md-6 offset-md-3 mainbox">

<div class="signup-box">

<h3 class="signup-title">Sign Up</h3>

<form action="/signup" method="post" class="needs-validation" novalidate>

<div class="mb-3">
<label for="username" class="form-label"><b>Username</b></label>
<input type="text" name="username" id="username" class="form-control" placeholder="Enter your Username" required>
<div class="valid-feedback">Looks good!</div>
</div>

<div class="mb-3">
<label for="email" class="form-label"><b>Email</b></label>
<input type="email" name="email" id="email" class="form-control" placeholder="Enter your email " required>
<div class="valid-feedback">Looks good!</div>
</div>

<div class="mb-3">
<label for="password" class="form-label"><b>Password</b></label>
<input type="password" name="password" id="password" class="form-control" placeholder="Create a strong Password" required>
<div class="valid-feedback">Looks good!</div>
</div>

<button class="signup-btn mt-3">Sign Up</button>

</form>

<p class="login-text">
Already have an account?
<a href="/login">Login</a>
</p>

</div>

</div>

</div>
